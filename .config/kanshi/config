profile secondary {
	output HDMI-A-1 {
		mode 1920x1080@75
		position 0,0
	}
	output eDP-1 disable
}

profile mirror {
	output HDMI-A-1 {
		mode 1920x1080@75
		position 0,0
	}
	output eDP-1 position 0,0
}

profile primary {
	output HDMI-A-1 disable
	output eDP-1 enable
}

profile {
	output eDP-1 enable
}
